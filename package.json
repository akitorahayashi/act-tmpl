{
  "name": "act-tmpl",
  "version": "0.1.0",
  "description": "TypeScript GitHub Action template repository",
  "private": true,
  "packageManager": "pnpm@11.1.3",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24.14.0 <25"
  },
  "scripts": {
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome check --formatter-enabled=true --linter-enabled=false --assist-enabled=false .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "package": "ncc build src/index.ts -o dist --license licenses.txt",
    "prepare": "husky"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.0.3",
    "@vercel/ncc": "^0.38.3",
    "@vitest/coverage-v8": "^3.2.4",
    "husky": "^9.1.7",
    "js-yaml": "^4.1.0",
    "lint-staged": "^17.0.5",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*": ["biome check --write --no-errors-on-unmatched"]
  }
}
